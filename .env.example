# UserCue Projects Portal — environment template
# Copy to .env and fill in. Never commit .env.

# ----- Backend -----

# Postgres
DATABASE_URL=postgresql+asyncpg://portal:portal@localhost:5432/portal_dev
TEST_DATABASE_URL=postgresql+asyncpg://portal:portal@localhost:5432/portal_test

# HTTP
PORTAL_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Magic link auth
AUTH_SIGNING_KEY=change-me-to-a-long-random-value
MAGIC_LINK_TTL_SECONDS=900

# Email (SES in prod; console in dev)
EMAIL_SENDER=noreply@projects.tryusercue.com
EMAIL_BACKEND=console   # console | ses
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 for attachments
S3_ATTACHMENTS_BUCKET=usercue-portal-attachments-dev

# Inbound email (Thread reply parsing)
INBOUND_EMAIL_DOMAIN=threads.projects.tryusercue.com
INBOUND_EMAIL_HMAC_SECRET=change-me

# Webhook signing
WEBHOOK_HMAC_SECRET=change-me

# Super-admin allowlist (comma-separated UserCue internal emails)
SUPER_ADMIN_EMAILS=brian@tryusercue.com,danny@tryusercue.com

# ----- Frontend -----
VITE_API_BASE=http://localhost:8000
